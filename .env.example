# --- Discord app ---
# 1. Go to https://discord.com/developers/applications → New Application.
# 2. Sidebar → Bot → Reset Token, paste below.
# 3. Same page: enable "Message Content Intent" (privileged toggle, easy to miss).
# 4. Sidebar → OAuth2 → URL Generator. Scopes: "bot". Bot permissions: "Send Messages",
#    "Embed Links", "Read Message History". Open the generated URL to invite the bot to a server.
DISCORD_TOKEN=

# --- Who can drive the bot ---
# Comma-separated Discord user IDs. Enable Developer Mode (Settings → Advanced),
# then right-click your name → Copy User ID.
ALLOWED_USER_IDS=

# Comma-separated channel IDs the bot will respond in.
# Right-click a channel → Copy Channel ID. Empty = any channel the bot is in.
ALLOWED_CHANNEL_IDS=

# --- Where Claude runs ---
# Default working directory for new sessions. Forward slashes on Windows.
DEFAULT_CWD=C:/Users/User
